# Copy this to .env or export these values in your shell.
# Never commit real Plaud tokens, cookies, or signed artifact URLs.

# Preferred: a Plaud workspace token from an authenticated session.
PLAUD_AUTH_TOKEN=""

# Alternative: a raw Cookie header copied from your own authenticated Plaud Web session.
# PLAUD_COOKIE=""

# Optional headers that can help match Plaud Web requests.
PLAUD_TIMEZONE="UTC"
PLAUD_LANGUAGE="en"
# PLAUD_DEVICE_ID=""
# PLAUD_USER_ID=""

# Optional output directory.
PLAUD_OUTPUT="./plaud-export"
